# Intel Trust Authority
ITA_API_KEY=your_ita_api_key_here
ITA_ENDPOINT=https://api.trustauthority.intel.com

# OPA
OPA_JURISDICTION=EU

# Model
HF_TOKEN=your_huggingface_token_here

# Ledger (gRPC server)
ARE_LEDGER_GRPC_PORT=9092
ARE_LEDGER_HEALTH_PORT=8080
ARE_LEDGER_METRICS_PORT=8083
ARE_LEDGER_DB_CONNECTION_STRING=host=postgres port=5432 user=ledger_app password=ledger_app dbname=ledger sslmode=disable
ARE_LEDGER_KAFKA_BOOTSTRAP_SERVERS=unused
ARE_LEDGER_KAFKA_SASL_USERNAME=unused
ARE_LEDGER_KAFKA_SASL_PASSWORD=unused

# Ledger REST Gateway
LEDGER_ENDPOINT=ledger:9092
GATEWAY_PORT=18099
GATEWAY_HOST=0.0.0.0
GATEWAY_CORS_ORIGINS=http://localhost:9001,http://localhost:9099,http://localhost:5173

# Postgres
POSTGRES_USER=ledger
POSTGRES_PASSWORD=ledger
POSTGRES_DB=ledger

# Praxis / Gateway (Doc 2)
SOVEREIGN_INFERENCE_TOKEN=generate_with_openssl_rand_hex_32

# ContextForge (Doc 2)
CONTEXTFORGE_ADMIN_PASSWORD=generate_secure_password
